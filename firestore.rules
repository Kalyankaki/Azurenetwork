// Firestore Security Rules for NRIVA Internship Portal
// Deploy via: Firebase Console > Firestore > Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'kalyank.123@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin'])
      );
    }
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if isAdmin();
      allow delete: if false;
    }
    match /internships/{docId} {
      allow read: if true;  // Public - internship listings are visible to everyone
      allow create: if request.auth != null;
      allow update: if request.auth != null && (resource.data.employerUid == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
    match /applications/{docId} {
      allow read: if request.auth != null && (
        resource.data.applicantUid == request.auth.uid ||
        resource.data.employerUid == request.auth.uid ||
        isAdmin()
      );
      allow create: if request.auth != null;
      // Applicant can accept/decline their own offer; employer can update their own postings' applications; admin can update anything
      allow update: if isAdmin() ||
        (request.auth != null && resource.data.applicantUid == request.auth.uid &&
          request.resource.data.status in ['offer_accepted', 'offer_declined']) ||
        (request.auth != null && resource.data.employerUid == request.auth.uid);
      allow delete: if false;
    }
    match /messages/{docId} {
      allow read: if request.auth != null && (resource.data.senderUid == request.auth.uid || isAdmin());
      allow create: if request.auth != null && request.resource.data.senderUid == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false;
    }
    match /activity/{docId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
    match /public_stats/{docId} {
      allow read: if true;  // Public - aggregate counts visible to everyone
      allow write: if request.auth != null;
    }
    match /notifications/{docId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update: if isAdmin();
      allow delete: if false;
    }
  }
}
