// Firestore Security Rules for NRIVA Internship Portal
// Deploy via: Firebase Console > Firestore > Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Bootstrap admin emails. Edit this list (and re-deploy rules) to add or
    // rotate super admins. Long-term: rely on the `roles` array instead and
    // shrink this list to a break-glass account only.
    function bootstrapAdminEmails() {
      return [
        'kalyank.123@gmail.com',
        'youth@nriva.org'
      ];
    }

    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email in bootstrapAdminEmails() ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin'])
      );
    }

    function isEmployer() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['employer']);
    }

    // Fields a user is NEVER allowed to set on their own user doc.
    function neverChangeable() {
      return ['uid', 'email', 'createdAt', 'coordinator', 'autoApproved'];
    }

    // Fields that can ONLY be set during the one-time onboarding transition
    // (onboarded flips false -> true). After onboarding, only an admin can
    // change them.
    function onboardingOnly() {
      return ['requestedRole', 'nrivaMembership', 'employerApproved'];
    }

    function isOnboardingTransition() {
      return resource.data.get('onboarded', false) == false &&
        request.resource.data.get('onboarded', false) == true;
    }

    // Self-update validator. Allows everyday profile edits AND the legitimate
    // role-bearing writes that happen during onboarding / employer auto-migrate,
    // while preventing privilege escalation to admin or self-approval.
    function selfUpdateAllowed() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();

      // Always-forbidden fields cannot be touched by self at all.
      // 'roles' may change but never to include 'admin'.
      // Onboarding-only fields are gated by isOnboardingTransition().
      return !changed.hasAny(neverChangeable())
        && (!('roles' in changed) || !('admin' in request.resource.data.roles))
        && (!changed.hasAny(onboardingOnly()) || (
          isOnboardingTransition()
          // Self may NEVER set employerApproved to true; admin does that.
          && (!('employerApproved' in changed) || request.resource.data.employerApproved == false)
        ));
    }

    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      // Self-update may not touch privileged fields; admins can update anything.
      allow update: if request.auth != null && (
        (request.auth.uid == userId && selfUpdateAllowed()) ||
        isAdmin()
      );
      // Self-delete (R11) and admin delete.
      allow delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /internships/{docId} {
      // Public read for listings (homepage stats, browsing)
      allow read: if true;
      // Only employers and admins can create internships
      allow create: if request.auth != null && (isEmployer() || isAdmin()) &&
        request.resource.data.employerUid == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.employerUid == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /applications/{docId} {
      // Applicant sees own, employer sees their internship apps, admin sees all
      allow read: if request.auth != null && (
        resource.data.applicantUid == request.auth.uid ||
        resource.data.employerUid == request.auth.uid ||
        isAdmin()
      );
      // Only authenticated users can create, must be their own application, status must be pending
      allow create: if request.auth != null &&
        request.resource.data.applicantUid == request.auth.uid &&
        request.resource.data.status == 'pending';
      // Applicant can accept/decline offers; employer can update their apps; admin can do anything
      allow update: if isAdmin() ||
        (request.auth != null && resource.data.applicantUid == request.auth.uid &&
          request.resource.data.status in ['offer_accepted', 'offer_declined']) ||
        (request.auth != null && resource.data.employerUid == request.auth.uid);
      // Applicant can delete their own application as part of account deletion (R11).
      allow delete: if request.auth != null && (
        resource.data.applicantUid == request.auth.uid || isAdmin()
      );
    }

    match /messages/{docId} {
      allow read: if request.auth != null && (
        resource.data.senderUid == request.auth.uid || isAdmin()
      );
      allow create: if request.auth != null &&
        request.resource.data.senderUid == request.auth.uid;
      allow update: if isAdmin();
      // Sender can delete their own messages as part of account deletion (R11).
      allow delete: if request.auth != null && (
        resource.data.senderUid == request.auth.uid || isAdmin()
      );
    }

    match /activity/{docId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    match /public_stats/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /notifications/{docId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update: if isAdmin();
      allow delete: if false;
    }
  }
}
