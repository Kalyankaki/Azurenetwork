// Firestore Security Rules for NRIVA Internship Portal
// Deploy via: Firebase Console > Firestore > Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'kalyank.123@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin'])
      );
    }

    function isEmployer() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['employer']);
    }

    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      // Users can update their own profile (onboarding), admins can update anyone (roles, coordinator)
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /internships/{docId} {
      // Public read for listings (homepage stats, browsing)
      allow read: if true;
      // Only employers and admins can create internships
      allow create: if request.auth != null && (isEmployer() || isAdmin()) &&
        request.resource.data.employerUid == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.employerUid == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /applications/{docId} {
      // Applicant sees own, employer sees their internship apps, admin sees all
      allow read: if request.auth != null && (
        resource.data.applicantUid == request.auth.uid ||
        resource.data.employerUid == request.auth.uid ||
        isAdmin()
      );
      // Only authenticated users can create, must be their own application, status must be pending
      allow create: if request.auth != null &&
        request.resource.data.applicantUid == request.auth.uid &&
        request.resource.data.status == 'pending';
      // Applicant can accept/decline offers; employer can update their apps; admin can do anything
      allow update: if isAdmin() ||
        (request.auth != null && resource.data.applicantUid == request.auth.uid &&
          request.resource.data.status in ['offer_accepted', 'offer_declined']) ||
        (request.auth != null && resource.data.employerUid == request.auth.uid);
      allow delete: if false;
    }

    match /messages/{docId} {
      allow read: if request.auth != null && (
        resource.data.senderUid == request.auth.uid || isAdmin()
      );
      allow create: if request.auth != null &&
        request.resource.data.senderUid == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /activity/{docId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    match /public_stats/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /notifications/{docId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update: if isAdmin();
      allow delete: if false;
    }
  }
}
